{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.envrc)",
      "Read(credentials.json)",
      "Read(credentials.*.json)",
      "Read(secret.json)",
      "Read(secrets.json)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(*.pfx)",
      "Read(*.p12)",
      "Read(*.crt)",
      "Read(*.cer)",
      "Read(id_rsa)",
      "Read(id_dsa)",
      "Read(id_ed25519)",
      "Read(**/.ssh/id_*)",
      "Read(*_key)",
      "Read(credentials)",
      "Read(web.config)",
      "Read(app.config)",
      "Read(**/helm/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.envrc)",
      "Edit(credentials.json)",
      "Edit(credentials.*.json)",
      "Edit(secret.json)",
      "Edit(secrets.json)",
      "Edit(*.key)",
      "Edit(*.pem)",
      "Edit(*.pfx)",
      "Edit(*.p12)",
      "Edit(*.crt)",
      "Edit(*.cer)",
      "Edit(id_rsa)",
      "Edit(id_dsa)",
      "Edit(id_ed25519)",
      "Edit(**/.ssh/id_*)",
      "Edit(*_key)",
      "Edit(credentials)",
      "Edit(web.config)",
      "Edit(app.config)",
      "Edit(**/helm/**)"
    ],
    "permissions": {
      "ask": [
        "WebFetch",
        "Bash(curl *)",
        "Bash(wget *)"
      ]
    }
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
